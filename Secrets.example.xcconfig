// Secrets.example.xcconfig
//
// Template for local build configuration. Copy this file to `Secrets.xcconfig`
// (which is gitignored) and fill in real values. These values are injected into
// the app's Info.plist and surfaced at runtime through `CoreKit.AppConfig`.
//
// NOTE: xcconfig treats `//` as a comment, so URLs must escape the double slash
// using the $() trick, e.g. `https:/$()/example.com`.
// The values below are intentionally unusable templates. A normal app launch
// must stop at the development-configuration setup screen until they are replaced.

API_BASE_URL = https:/$()/api.chapterflow.example.com
COGNITO_REGION = us-east-1
COGNITO_USER_POOL_ID = us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID = XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_DOMAIN = auth.your-domain.auth.us-east-1.amazoncognito.com

// Sentry crash reporting DSN. Leave empty to disable Sentry (recommended for
// Debug builds). Obtain from your Sentry project → Settings → Client Keys.
// Format: https:/$()/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN =

// StoreKit 2 product IDs — must match your App Store Connect subscription group exactly.
// One subscription group; monthly and annual are auto-renewable. Upfront is optional.
// E.g. com.chapterflow.ios.pro.monthly
SK_MONTHLY_PRODUCT_ID = com.chapterflow.ios.pro.monthly
SK_ANNUAL_PRODUCT_ID = com.chapterflow.ios.pro.annual
// Leave empty to omit the annual-upfront tier from the paywall.
SK_ANNUAL_UPFRONT_PRODUCT_ID =
