// Optional local app-target overrides. Copy to the gitignored
// `Secrets.xcconfig` and fill only the values needed for local integration.
// A clean checkout does not require this file. Release automation never copies
// this template; it generates Secrets.xcconfig from validated protected inputs.
//
// xcconfig treats // as a comment. Escape URL separators as :/$()/.

API_BASE_URL =
COGNITO_REGION =
COGNITO_USER_POOL_ID =
COGNITO_CLIENT_ID =
COGNITO_DOMAIN =

APP_STORE_ID =
APP_STORE_URL =
SUPPORT_URL =

// `disabled` or `enabled`. An enabled Release requires a valid SENTRY_DSN.
SENTRY_POLICY = disabled
SENTRY_DSN =

// Comma-separated owner-approved catalog plus the selected product IDs.
APPROVED_STOREKIT_PRODUCT_IDS =
SK_MONTHLY_PRODUCT_ID =
SK_ANNUAL_PRODUCT_ID =
// Reserved; must remain empty until backend non-renewing verification is implemented.
SK_ANNUAL_UPFRONT_PRODUCT_ID =

// Optional local provenance. Release automation writes the immutable full commit SHA.
BUILD_COMMIT_SHA =
