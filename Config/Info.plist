<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Partial Info.plist. Standard keys (CFBundleIdentifier, versions, scene
	  manifest, launch screen) are injected by GENERATE_INFOPLIST_FILE=YES and
	  the INFOPLIST_KEY_* build settings. Only the custom, xcconfig-injected
	  configuration keys live here. Surfaced at runtime via CoreKit.AppConfig.
	-->
	<key>APIBaseURL</key>
	<string>$(API_BASE_URL)</string>
	<key>CognitoRegion</key>
	<string>$(COGNITO_REGION)</string>
	<key>CognitoUserPoolID</key>
	<string>$(COGNITO_USER_POOL_ID)</string>
	<key>CognitoClientID</key>
	<string>$(COGNITO_CLIENT_ID)</string>
	<key>CognitoDomain</key>
	<string>$(COGNITO_DOMAIN)</string>
	<key>SentryDSN</key>
	<string>$(SENTRY_DSN)</string>
	<key>SKMonthlyProductID</key>
	<string>$(SK_MONTHLY_PRODUCT_ID)</string>
	<key>SKAnnualProductID</key>
	<string>$(SK_ANNUAL_PRODUCT_ID)</string>
	<key>SKAnnualUpfrontProductID</key>
	<string>$(SK_ANNUAL_UPFRONT_PRODUCT_ID)</string>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.chapterflow.ios.tokenRefresh</string>
		<string>com.chapterflow.ios.syncRefresh</string>
		<string>com.chapterflow.ios.contentPrefetch</string>
	</array>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
		<string>processing</string>
		<string>remote-notification</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.chapterflow.ios</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>chapterflow</string>
			</array>
		</dict>
	</array>
	<!--
	  NSUserActivityTypes — declare activity types the app can handle for
	  Handoff (Continuity). The reading activity lets a chapter started on
	  another device (or web) continue seamlessly on this device.
	-->
	<key>NSUserActivityTypes</key>
	<array>
		<string>com.chapterflow.ios.reading</string>
	</array>
</dict>
</plist>
