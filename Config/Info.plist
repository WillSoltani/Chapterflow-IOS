<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Partial Info.plist. Standard keys (CFBundleIdentifier, versions, scene
	  manifest, launch screen) are injected by GENERATE_INFOPLIST_FILE=YES and
	  the INFOPLIST_KEY_* build settings. Only the custom, xcconfig-injected
	  configuration keys live here. Surfaced at runtime via CoreKit.AppConfig.
	-->
	<key>APIBaseURL</key>
	<string>$(API_BASE_URL)</string>
	<key>ChapterFlowEnvironment</key>
	<string>$(CHAPTERFLOW_ENVIRONMENT)</string>
	<key>BundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>AppStoreID</key>
	<string>$(APP_STORE_ID)</string>
	<key>AppStoreURL</key>
	<string>$(APP_STORE_URL)</string>
	<key>SupportURL</key>
	<string>$(SUPPORT_URL)</string>
	<key>SentryPolicy</key>
	<string>$(SENTRY_POLICY)</string>
	<key>BuildConfiguration</key>
	<string>$(BUILD_CONFIGURATION)</string>
	<key>BuildCommitSHA</key>
	<string>$(BUILD_COMMIT_SHA)</string>
	<key>BackendDeploymentCommitSHA</key>
	<string>$(BACKEND_DEPLOYMENT_COMMIT_SHA)</string>
	<key>BackendAttestationID</key>
	<string>$(BACKEND_ATTESTATION_ID)</string>
	<key>MarketingVersion</key>
	<string>$(MARKETING_VERSION)</string>
	<key>BuildNumber</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>ReleaseManifestFingerprint</key>
	<string>$(RELEASE_MANIFEST_FINGERPRINT)</string>
	<key>CognitoRegion</key>
	<string>$(COGNITO_REGION)</string>
	<key>CognitoUserPoolID</key>
	<string>$(COGNITO_USER_POOL_ID)</string>
	<key>CognitoClientID</key>
	<string>$(COGNITO_CLIENT_ID)</string>
	<key>CognitoDomain</key>
	<string>$(COGNITO_DOMAIN)</string>
	<key>SentryDSN</key>
	<string>$(SENTRY_DSN)</string>
	<key>SKMonthlyProductID</key>
	<string>$(SK_MONTHLY_PRODUCT_ID)</string>
	<key>SKAnnualProductID</key>
	<string>$(SK_ANNUAL_PRODUCT_ID)</string>
	<key>SKAnnualUpfrontProductID</key>
	<string>$(SK_ANNUAL_UPFRONT_PRODUCT_ID)</string>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.chapterflow.ios.tokenRefresh</string>
		<string>com.chapterflow.ios.syncRefresh</string>
		<string>com.chapterflow.ios.contentPrefetch</string>
	</array>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
		<string>processing</string>
		<string>remote-notification</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.chapterflow.ios</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>chapterflow</string>
			</array>
		</dict>
	</array>
	<!--
	  NSUserActivityTypes — declare activity types the app can handle for
	  Handoff (Continuity). The reading activity lets a chapter started on
	  another device (or web) continue seamlessly on this device.
	-->
	<key>NSUserActivityTypes</key>
	<array>
		<string>com.chapterflow.ios.reading</string>
	</array>
	<!--
	  UIApplicationShortcutItems — static Home-screen quick actions (P8.6).
	  Taps are routed via QuickActionBridge → AppModel.consumeQuickAction().
	  A dynamic "Continue Reading" entry (with current book title) is set by
	  IntentDonationManager.update() after each session to supplement these.
	-->
	<key>UIApplicationShortcutItems</key>
	<array>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>com.chapterflow.ios.continue-reading</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Continue Reading</string>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>book.fill</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>com.chapterflow.ios.reviews</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Reviews</string>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>star.fill</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>com.chapterflow.ios.ask</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Ask the Book</string>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>sparkles</string>
		</dict>
	</array>
</dict>
</plist>
