<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Partial Info.plist. Standard keys (CFBundleIdentifier, versions, scene
	  manifest, launch screen) are injected by GENERATE_INFOPLIST_FILE=YES and
	  the INFOPLIST_KEY_* build settings. Only the custom, xcconfig-injected
	  configuration keys live here. Surfaced at runtime via CoreKit.AppConfig.
	-->
	<key>APIBaseURL</key>
	<string>$(API_BASE_URL)</string>
	<key>CognitoRegion</key>
	<string>$(COGNITO_REGION)</string>
	<key>CognitoUserPoolID</key>
	<string>$(COGNITO_USER_POOL_ID)</string>
	<key>CognitoClientID</key>
	<string>$(COGNITO_CLIENT_ID)</string>
	<!--
	  Custom URL scheme for deep links (chapterflow://…). Handled by
	  AppFeature's DeepLinkParser via SwiftUI's onOpenURL. Universal links
	  (https) are wired later via an associated-domains entitlement.
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.chapterflow.ios.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>chapterflow</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
